[global]
    follow = mouse
    font = JetBrainsMono NFM 10
    width = 400
    height = (0, 200)
    offset = (10, 10)
    origin = top-right
    gap_size = 5
    corner_radius = 8
    frame_width = 2
    frame_color = "#b4befe"
    separator_height = 2
    separator_color = frame
    padding = 8
    horizontal_padding = 12
    timeout = 5
    history_length = 100
    notification_limit = 20

    # Colors
    background = "#1e1e2e"
    foreground = "#cdd6f4"

    # Click behavior — needed for -A actions
    mouse_left_click = do_action, close_current
    mouse_right_click = close_current

[urgency_low]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#b4befe"
    timeout = 5

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#b4befe"
    timeout = 5

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#fab387"
    timeout = 0
